# ==============================================================================
# Filename:       pops-bot/systemd/pops-bot.service
# Version:        1.0
# Author:         Claude Code
# Last Modified:  2026-06-12
# Context:        http://trac.home.arpa/ticket/3576
#
# Purpose:
#   Systemd service unit for the Pops KMS Telegram bot (python-telegram-bot
#   long-polling). Runs persistently on athena as user will. Deployed by
#   playbooks/deploy_pops_bot.yml. Parent ticket: Trac #3577.
#   Service start is held until TELEGRAM_BOT_TOKEN is set to a real value
#   (not REPLACE_ME) in /etc/pops-bot/env.
#
# Secrets:
#   TELEGRAM_BOT_TOKEN, POPS_API_KEY (/etc/pops-bot/env, mode 0640 root:will)
#
# Revision History:
#   v1.0 (2026-06-12) - Initial unit file. Trac #3576.
# ==============================================================================

[Unit]
Description=Pops KMS Telegram bot (long-polling)
After=network-online.target pops-api.service
Wants=network-online.target

[Service]
User=will
Group=will
WorkingDirectory=/home/will/ansible-netbox/pops-bot
EnvironmentFile=/etc/pops-bot/env
ExecStart=/opt/venvs/gemini_projects/bin/python3 -m bot.main
Restart=on-failure
RestartSec=10

[Install]
WantedBy=multi-user.target
